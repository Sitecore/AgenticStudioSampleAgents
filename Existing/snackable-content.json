  "schemas": [
    {
      "id": "linkedin_post_schema",
      "name": "LinkedIn Post Schema",
      "schema": {
        "type": "object",
        "required": [
          "headline",
          "body",
          "call_to_action",
          "hashtags",
          "mentions"
        ],
        "properties": {
          "body": {
            "type": "string",
            "description": "Main content (max 3000 characters)"
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 5,
            "description": "Relevant hashtags (3-5 recommended)"
          },
          "headline": {
            "type": "string",
            "description": "Attention-grabbing headline or opening line"
          },
          "mentions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "People or companies to tag"
          },
          "call_to_action": {
            "type": "string",
            "description": "Clear call-to-action"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for LinkedIn professional content"
    },
    {
      "id": "twitter_post_schema",
      "name": "Twitter/X Post Schema",
      "schema": {
        "type": "object",
        "required": [
          "text",
          "hashtags",
          "thread"
        ],
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 280,
            "description": "Tweet content (max 280 characters)"
          },
          "thread": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Additional tweets for thread (optional)"
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 2,
            "description": "Hashtags (1-2 recommended)"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for Twitter/X concise content"
    },
    {
      "id": "instagram_post_schema",
      "name": "Instagram Post Schema",
      "schema": {
        "type": "object",
        "required": [
          "caption",
          "image_description",
          "hashtags",
          "call_to_action"
        ],
        "properties": {
          "caption": {
            "type": "string",
            "description": "Post caption (max 2200 characters)"
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Relevant hashtags (10-30 recommended)"
          },
          "call_to_action": {
            "type": "string",
            "description": "Call-to-action in caption"
          },
          "image_description": {
            "type": "string",
            "description": "Description of ideal image/visual"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for Instagram visual-first content"
    },
    {
      "id": "facebook_post_schema",
      "name": "Facebook Post Schema",
      "schema": {
        "type": "object",
        "required": [
          "text",
          "question",
          "call_to_action",
          "link"
        ],
        "properties": {
          "link": {
            "type": "string",
            "description": "URL to share (optional)"
          },
          "text": {
            "type": "string",
            "description": "Post text content"
          },
          "question": {
            "type": "string",
            "description": "Engagement question (optional)"
          },
          "call_to_action": {
            "type": "string",
            "description": "Call-to-action or link context"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for Facebook community content"
    },
    {
      "id": "email_content_schema",
      "name": "Email Content Schema",
      "schema": {
        "type": "object",
        "required": [
          "subject_line",
          "body",
          "call_to_action",
          "preview_text",
          "greeting",
          "cta_url",
          "closing"
        ],
        "properties": {
          "body": {
            "type": "string",
            "description": "Main email content"
          },
          "closing": {
            "type": "string",
            "description": "Email closing/signature"
          },
          "cta_url": {
            "type": "string",
            "description": "CTA button URL"
          },
          "greeting": {
            "type": "string",
            "description": "Email greeting"
          },
          "preview_text": {
            "type": "string",
            "description": "Preview/preheader text"
          },
          "subject_line": {
            "type": "string",
            "description": "Email subject line (50-60 characters recommended)"
          },
          "call_to_action": {
            "type": "string",
            "description": "Primary CTA text"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for email marketing content"
    },
    {
      "id": "blog_post_schema",
      "name": "Blog Post Schema",
      "schema": {
        "type": "object",
        "required": [
          "title",
          "introduction",
          "body",
          "conclusion",
          "meta_description",
          "call_to_action",
          "keywords"
        ],
        "properties": {
          "body": {
            "type": "string",
            "description": "Main content with headers and sections"
          },
          "title": {
            "type": "string",
            "description": "SEO-optimized blog title"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "SEO keywords"
          },
          "conclusion": {
            "type": "string",
            "description": "Closing paragraph"
          },
          "introduction": {
            "type": "string",
            "description": "Opening paragraph/hook"
          },
          "call_to_action": {
            "type": "string",
            "description": "CTA at end of post"
          },
          "meta_description": {
            "type": "string",
            "description": "Meta description (150-160 characters)"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for blog content"
    }
  ],
  "htmlTemplates": [
    {
      "id": "linkedin_post_template",
      "name": "LinkedIn Post Template",
      "template": "<div class=\"linkedin-post\">\n  <div class=\"headline\"><strong>{{headline}}</strong></div>\n  <div class=\"body\">{{body}}</div>\n  <div class=\"hashtags\">{{#each hashtags}}<span class=\"hashtag\">#{{this}}</span> {{/each}}</div>\n  <div class=\"cta\">{{call_to_action}}</div>\n  {{#if mentions}}<div class=\"mentions\">{{#each mentions}}<span class=\"mention\">@{{this}}</span> {{/each}}</div>{{/if}}\n</div>"
    },
    {
      "id": "twitter_post_template",
      "name": "Twitter/X Post Template",
      "template": "<div class=\"twitter-post\">\n  <div class=\"tweet-text\">{{text}}</div>\n  {{#if hashtags}}<div class=\"hashtags\">{{#each hashtags}}<span class=\"hashtag\">#{{this}}</span> {{/each}}</div>{{/if}}\n  {{#if thread}}<div class=\"thread\">{{#each thread}}<div class=\"thread-tweet\">{{this}}</div>{{/each}}</div>{{/if}}\n</div>"
    },
    {
      "id": "instagram_post_template",
      "name": "Instagram Post Template",
      "template": "<div class=\"instagram-post\">\n  <div class=\"image-placeholder\">📷 {{image_description}}</div>\n  <div class=\"caption\">{{caption}}</div>\n  <div class=\"hashtags\">{{#each hashtags}}<span class=\"hashtag\">#{{this}}</span> {{/each}}</div>\n  {{#if call_to_action}}<div class=\"cta\">{{call_to_action}}</div>{{/if}}\n</div>"
    },
    {
      "id": "facebook_post_template",
      "name": "Facebook Post Template",
      "template": "<div class=\"facebook-post\">\n  <div class=\"text\">{{text}}</div>\n  {{#if question}}<div class=\"question\">❓ {{question}}</div>{{/if}}\n  {{#if link}}<div class=\"link\">🔗 <a href=\"{{link}}\">{{call_to_action}}</a></div>{{else}}<div class=\"cta\">{{call_to_action}}</div>{{/if}}\n</div>"
    },
    {
      "id": "email_content_template",
      "name": "Email Content Template",
      "template": "<div class=\"email-content\">\n  <div class=\"subject\"><strong>Subject:</strong> {{subject_line}}</div>\n  <div class=\"preview\"><em>{{preview_text}}</em></div>\n  <div class=\"email-body\">\n    <p>{{greeting}}</p>\n    <div class=\"content\">{{body}}</div>\n    <div class=\"cta-section\">\n      <a href=\"{{cta_url}}\" class=\"cta-button\">{{call_to_action}}</a>\n    </div>\n    <p class=\"closing\">{{closing}}</p>\n  </div>\n</div>"
    },
    {
      "id": "blog_post_template",
      "name": "Blog Post Template",
      "template": "<article class=\"blog-post\">\n  <header>\n    <h1>{{title}}</h1>\n    <meta name=\"description\" content=\"{{meta_description}}\">\n  </header>\n  <div class=\"introduction\">{{introduction}}</div>\n  <div class=\"body-content\">{{body}}</div>\n  <div class=\"conclusion\">{{conclusion}}</div>\n  <div class=\"cta-section\">{{call_to_action}}</div>\n  {{#if keywords}}<div class=\"keywords\">Keywords: {{#each keywords}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>{{/if}}\n</article>"
    }
  ],
  "actions": [
    {
      "id": "initialize_flow",
      "kind": "InitializeFlow",
      "displayName": "Initialize",
      "showToUser": false
    },
    {
      "id": "retrieve_context_params",
      "kind": "RetrieveContextParameterDocs",
      "config": {
        "outputVarName": "contextParameterDocuments",
        "workflowTypeFilter": "account-enrichment",
        "filterByCurrentFlow": true
      },
      "showToUser": false,
      "displayName": "Retrieve Context Parameters"
    },
    {
      "id": "extract_params",
      "kind": "ExtractContextParams",
      "config": {
        "inputVarName": "__messages__",
        "outputVarName": "contextParams"
      },
      "showToUser": false,
      "displayName": "Extract Parameters"
    },
    {
      "id": "review_params",
      "kind": "ReviewContextParams",
      "config": {
        "inputVarName": "vars.contextParams",
        "outputVarName": "reviewedContextParams"
      },
      "showToUser": true,
      "displayName": "Review Parameters"
    },
    {
      "id": "normalize_params",
      "kind": "NormalizeParams",
      "config": {
        "inputVarName": "vars.reviewedContextParams",
        "outputVarName": "normalizedParams"
      },
      "showToUser": false,
      "displayName": "Normalize Parameters"
    },
    {
      "id": "expand_variants",
      "kind": "ExpandVariants",
      "config": {
        "inputVarName": "vars.normalizedParams",
        "outputVarName": "variants",
        "contextParamsVarName": "contextParameterDocuments"
      },
      "showToUser": false,
      "displayName": "Expand Variants"
    },
    {
      "id": "content_generation_loop",
      "kind": "Foreach",
      "index": "variantIndex",
      "items": "=variants",
      "value": "currentVariant",
      "actions": [
        {
          "id": "extract_variant_structure",
          "kind": "ExtractVariantStructure",
          "config": {
            "loopVarName": "loop_content_generation_loop",
            "structureKey": "channels",
            "outputSchemaVarName": "structuredSchema",
            "outputHtmlTemplateVarName": "htmlTemplate"
          },
          "showToUser": false,
          "displayName": "Extract Structure"
        },
        {
          "id": "compose_variant_message",
          "kind": "ComposeMessageForVariant",
          "config": {
            "loopVarName": "loop_content_generation_loop",
            "systemPrompt": "Generate content based on the user request and the provided variant parameters.",
            "outputVarName": "variantMessage",
            "messageTemplate": "Generate content for: {variantDescription}",
            "includeOptionDetails": true
          },
          "showToUser": false,
          "displayName": "Compose Message"
        },
        {
          "id": "generate_content",
          "kind": "GenerateContent",
          "config": {
            "model": "workflow-fast-model",
            "loopVarName": "loop_content_generation_loop",
            "temperature": 0.7,
            "artifactKind": "content_item",
            "inputVarName": "vars.variantMessage",
            "outputVarName": "generatedContent",
            "htmlTemplateVar": "vars.htmlTemplate",
