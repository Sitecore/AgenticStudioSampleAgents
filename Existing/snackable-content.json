{
  "schema_version": "2.0",
  "id": "snackable-content",
  "name": "Snackable Content Generator",
  "description": "The Snackable Content Generator creates short-form, engaging social media content optimized for quick consumption across various platforms.",
  "gettingStarted": {
    "title": "What is Snackable Content Generator?",
    "howItWorks": "Provide your key message or source content, and the agent will transform it into bite-sized posts, quotes, and snippets perfect for social sharing.",
    "whatIsItFor": "The Snackable Content Generator creates short-form, engaging social media content optimized for quick consumption across various platforms."
  },
  "inputs": [
    {
      "type": "prompt",
      "label": "Content Requirements",
      "minLines": 3,
      "required": true,
      "description": "Describe the content you want to generate",
      "placeholder": "Tell us about your content needs..."
    },
    {
      "type": "context",
      "label": "Ground with context",
      "required": false,
      "description": "Optionally select artifacts or knowledge to provide additional context"
    },
    {
      "type": "file-upload",
      "label": "Add more context",
      "required": false,
      "description": "Please add any reference materials"
    }
  ],
