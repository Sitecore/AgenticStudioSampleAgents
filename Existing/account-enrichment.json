{
  "schema_version": "2.0",
  "id": "account-enrichment",
  "name": "Account Data Enrichment",
  "description": "Account data enrichment workflow with single Foreach loop. Parses accounts, enriches each one with web research, saves individual documents, then creates a summary report.",
  "gettingStarted": {
    "title": "What is Account Enrichment?",
    "howItWorks": "Upload a CSV file containing account information. The agent will process each account, conduct web research, and generate detailed enrichment reports for each company along with a summary document.",
    "whatIsItFor": "The Account Enrichment agent enriches company data by researching each account and gathering comprehensive information including company details, size, products, leadership, and recent news."
  },
  "inputs": [
    {
      "type": "text-input",
      "label": "Input",
      "required": false,
      "multiline": true,
      "description": "Describe the accounts you want to enrich",
      "placeholder": "Tell us about the accounts..."
    },
    {
      "type": "context",
      "label": "Ground with context",
      "required": false,
      "description": "Optionally select artifacts or knowledge to provide additional context"
    },
    {
      "type": "file-upload",
      "label": "Upload CSV",
      "accept": ".csv",
      "maxFiles": 1,
      "required": false,
      "description": "Upload a CSV file containing the accounts to enrich"
    }
  ],
  "contextParameters": [],
  "schemas": [
    {
      "id": "account_enrichment_schema",
      "name": "Account Enrichment Schema",
      "schema": {
        "type": "object",
        "required": [
          "accountName",
          "industry",
          "location",
          "companySize",
          "revenue",
          "products",
          "leadership",
          "recentNews",
          "website"
        ],
        "properties": {
          "revenue": {
            "type": "string",
            "description": "Annual revenue or revenue range if available"
          },
          "website": {
            "type": "string",
            "description": "Company website URL"
          },
          "industry": {
            "type": "string",
            "description": "The primary industry or sector the company operates in"
          },
          "location": {
            "type": "string",
            "description": "Company headquarters location (city, state/country)"
          },
          "products": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Key products and services offered by the company"
          },
          "leadership": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "title"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "description": "Key leadership team members (CEO, executives, etc.)"
          },
          "recentNews": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title",
                "date",
                "summary"
              ],
              "properties": {
                "date": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "description": "Recent news articles and developments about the company"
          },
          "accountName": {
            "type": "string",
            "description": "The name of the company/account"
          },
          "companySize": {
            "type": "string",
            "description": "Company size (number of employees or revenue range)"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for enriching account information with structured data from web research"
    }
  ],
  "htmlTemplates": [],
  "actions": [
    {
      "id": "initialize_flow",
      "kind": "InitializeFlow",
      "displayName": "Initialize",
      "showToUser": false
    },
    {
      "id": "parse_accounts",
      "kind": "ParseAccounts",
      "config": {
        "inputVarName": "__messages__",
        "outputVarName": "accounts"
      },
      "showToUser": true,
      "displayName": "Parse Accounts"
    },
    {
      "id": "account_enrichment_loop",
      "kind": "Foreach",
      "index": "accountIndex",
      "items": "=accounts",
      "value": "currentAccount",
      "actions": [
        {
          "id": "get_enrichment_schema",
          "kind": "GetStructuredSchema",
          "config": {
            "schemaType": "account_enrichment_schema",
            "outputVarName": "enrichmentSchema"
          },
          "showToUser": false,
          "displayName": "Get Schema"
        },
        {
          "id": "enrich_account",
          "kind": "StructuredResearchFromLoop",
          "config": {
            "model": "workflow-fast-model",
            "loopVarName": "loop_account_enrichment_loop",
            "systemPrompt": "You are a business research agent specializing in company data enrichment.\n\nResearch the company thoroughly using web search and extract:\n- Basic company information (name, industry, location)\n- Company size and revenue information\n- Key products and services\n- Leadership and key people\n- Recent news and developments\n\nBe thorough and accurate. Use multiple sources when possible.",
            "outputVarName": "currentEnrichedAccount",
            "queryTemplate": "Research information about the company: {accountName}",
            "structuredSchemaVar": "vars.enrichmentSchema"
          },
          "showToUser": true,
          "displayName": "Enrich Account"
        },
        {
          "id": "save_document",
          "kind": "SaveDocument",
          "config": {
            "kind": "extract",
            "titlePrefix": "Account Enrichment",
            "contentVarName": "vars.currentEnrichedAccount",
            "documentIdPath": "documentId",
            "titleSuffixPath": "accountName"
          },
          "showToUser": false,
          "displayName": "Save Document"
        },
        {
          "id": "append_result",
          "kind": "AppendLoopResult",
          "config": {
            "loopVarName": "loop_account_enrichment_loop",
            "resultVarName": "vars.currentEnrichedAccount"
          },
          "showToUser": false,
          "displayName": "Store Result"
        }
      ],
      "showToUser": false,
      "displayName": "Enrich Each Account"
    },
    {
      "id": "extract_enriched_accounts",
      "kind": "ExtractLoopResults",
      "config": {
        "loopVarName": "loop_account_enrichment_loop",
        "outputVarName": "enrichedAccounts"
      },
      "showToUser": false,
      "displayName": "Extract Results"
    },
    {
      "id": "format_report",
      "kind": "FormatEnrichedAccounts",
      "config": {
        "inputVarName": "vars.enrichedAccounts",
        "outputVarName": "formattedReport"
      },
      "showToUser": true,
      "displayName": "Format Report"
    },
    {
      "id": "save_enriched_data",
      "kind": "SaveDocument",
      "config": {
        "kind": "text",
        "titlePrefix": "Account Enrichment Report",
        "contentVarName": "vars.formattedReport",
        "successMessage": "\n\n✅ Account enrichment completed and saved!\n**Document:** {title}\n**ID:** {id}",
        "documentIdVarName": "vars.documentId"
      },
      "showToUser": false,
      "displayName": "Save Report"
    },
    {
      "id": "workflow_end",
      "kind": "WorkflowEnd",
      "displayName": "Complete",
      "showToUser": false
    }
  ],
  "version": 2,
  "is_active": true
}