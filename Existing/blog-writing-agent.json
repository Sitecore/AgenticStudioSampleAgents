{
  "schema_version": "2.0",
  "id": "blog-writing-agent",
  "name": "Blog Writing Agent",
  "description": "Research, write, and save workflow with approval. Performs deep research, saves it, gets human approval, then generates a structured blog post.",
  "gettingStarted": {
    "title": "What is Blog Writing Agent?",
    "howItWorks": "Describe your blog topic. The agent will research the subject, present findings for your approval, and then generate a complete blog post with metadata and SEO elements.",
    "whatIsItFor": "The Blog Writing Agent creates high-quality blog posts by first conducting comprehensive research, then generating engaging, well-structured content with proper SEO optimization."
  },
  "inputs": [
    {
      "type": "prompt",
      "label": "Blog Topic",
      "minLines": 3,
      "required": true,
      "description": "Describe what you want to write about",
      "placeholder": "Tell us about your blog topic..."
    }
  ],
  "contextParameters": [],
  "schemas": [
    {
      "id": "blog",
      "name": "Blog Post Schema",
      "schema": {
        "type": "object",
        "required": [
          "title",
          "excerpt",
          "content",
          "tags",
          "seo",
          "audience"
        ],
        "properties": {
          "seo": {
            "type": "object",
            "required": [
              "meta_description",
              "focus_keyword"
            ],
            "properties": {
              "focus_keyword": {
                "type": "string",
                "description": "Primary SEO keyword"
              },
              "meta_description": {
                "type": "string",
                "description": "SEO meta description (50-160 characters)"
              }
            },
            "description": "SEO-related metadata",
            "additionalProperties": false
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Relevant tags or keywords for the blog post"
          },
          "title": {
            "type": "string",
            "description": "The blog post title"
          },
          "content": {
            "type": "string",
            "description": "The full blog post content in markdown format"
          },
          "excerpt": {
            "type": "string",
            "description": "A brief excerpt or summary of the blog post"
          },
          "audience": {
            "type": "object",
            "required": [
              "intended_audience",
              "audience_characteristics",
              "audience_needs"
            ],
            "properties": {
              "audience_needs": {
                "type": "string",
                "description": "Key needs the content addresses"
              },
              "intended_audience": {
                "type": "string",
                "description": "Description of the intended audience"
              },
              "audience_characteristics": {
                "type": "object",
                "required": [
                  "age_range",
                  "location",
                  "interests",
                  "professional_background"
                ],
                "properties": {
                  "location": {
                    "type": "string",
                    "description": "Geographic focus (e.g., Global, North America)"
                  },
                  "age_range": {
                    "type": "string",
                    "description": "Target age range (e.g., 25-45, All ages)"
                  },
                  "interests": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Main interests relevant to the audience"
                  },
                  "professional_background": {
                    "type": "string",
                    "description": "Professional or educational background"
                  }
                },
                "additionalProperties": false
              }
            },
            "description": "Target audience information",
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "description": "Structured schema for blog post generation with SEO and audience metadata"
    }
  ],
  "htmlTemplates": [
    {
      "id": "blog-template",
      "name": "Standard Blog Template",
      "template": "<article class=\"blog-post\">\n  <header>\n    <h1>{{title}}</h1>\n    <p class=\"excerpt\">{{excerpt}}</p>\n    <div class=\"meta\">\n      <span class=\"tags\">{{#each tags}}<span class=\"tag\">{{this}}</span>{{/each}}</span>\n    </div>\n  </header>\n  <div class=\"content\">\n    {{content}}\n  </div>\n  <footer>\n    <div class=\"audience-info\">\n      <h3>Target Audience</h3>\n      <p>{{audience.intended_audience}}</p>\n    </div>\n  </footer>\n</article>"
    }
  ],
  "actions": [
    {
      "id": "initialize_flow",
      "kind": "InitializeFlow",
      "displayName": "Initialize",
      "showToUser": false
    },
    {
      "id": "research",
      "kind": "DeepResearch",
      "config": {
        "model": "web-search-model",
        "inputVarName": "__messages__",
        "systemPrompt": "You are a deep research agent.\n  \n  Goals:\n  - Perform web research using available web_search tools\n  - Cite findings implicitly in your analysis\n  - Produce a structured, comprehensive research report\n  \n  Output format:\n  # [Title]\n  \n  ## Executive Summary\n  Brief overview of findings\n  \n  ## Key Findings\n  - Finding 1\n  - Finding 2\n  - Finding 3\n  \n  ## Detailed Analysis\n  Comprehensive analysis of the research topic\n  \n  ## Sources\n  - [Source 1 URL]\n  - [Source 2 URL]",
        "outputVarName": "researchContent"
      },
      "showToUser": true,
      "displayName": "Research"
    },
    {
      "id": "save_research",
      "kind": "SaveDocument",
      "config": {
        "kind": "research",
        "titlePrefix": "Research Document",
        "contentVarName": "vars.researchContent",
        "documentIdVarName": "vars.documentId"
      },
      "showToUser": false,
      "displayName": "Save Research"
    },
    {
      "id": "approval",
      "kind": "Approval",
      "showToUser": true,
      "displayName": "Approval"
    },
    {
      "id": "get_schema",
      "kind": "GetStructuredSchema",
      "config": {
        "schemaType": "blog",
        "outputVarName": "structuredSchema",
        "schemaHtmlTemplate": "blog-template",
        "outputHtmlTemplateVarName": "htmlTemplate"
      },
      "showToUser": false,
      "displayName": "Get Schema"
    },
    {
      "id": "compose_message",
      "kind": "ComposeMessage",
      "config": {
        "inputVarNames": [
          "vars.researchContent"
        ],
        "outputVarName": "blogPrompt",
        "messageTemplate": "Based on the following user request and research findings, write a comprehensive, engaging blog post.\n  \n  User Request:\n  {userMessage}\n  \n  Research Findings:\n  {researchContent}\n  \n  Instructions:\n  - Write in a clear, engaging style\n  - Use proper markdown formatting\n  - Include relevant facts and insights from the research\n  - Structure the blog with clear sections\n  - Make it informative and actionable\n  - Provide comprehensive SEO metadata\n  - Define the target audience clearly",
        "includeUserMessage": true
      },
      "showToUser": false,
      "displayName": "Compose Prompt"
    },
    {
      "id": "generate_content",
      "kind": "GenerateContent",
      "config": {
        "model": "workflow-fast-model",
        "temperature": 0.7,
        "artifactKind": "content_item",
        "inputVarName": "vars.blogPrompt",
        "systemPrompt": "You are an expert content writer. Create high-quality, engaging blog content based on the provided prompt and research.",
        "outputVarName": "blogContent",
        "structuredSchemaVar": "vars.structuredSchema"
      },
      "showToUser": true,
      "displayName": "Generate Content"
    },
    {
      "id": "save_blog",
      "kind": "SaveDocument",
      "config": {
        "kind": "content_item",
        "titlePrefix": "Blog Post",
        "contentVarName": "vars.blogContent",
        "documentIdVarName": "vars.documentId"
      },
      "showToUser": false,
      "displayName": "Save"
    },
    {
      "id": "workflow_end",
      "kind": "WorkflowEnd",
      "displayName": "Complete",
      "showToUser": false
    }
  ],
  "version": 2,
  "is_active": true
}