{
  "schema_version": "2.0",
  "id": "audience-summary",
  "name": "Audience Summary",
  "description": "Summarize target industries, audience segments, and timely news into a concise brief.",
  "gettingStarted": {
    "title": "What is Audience Summary?",
    "howItWorks": "Provide information about your target industries or audience segments. The agent will research current trends, news, and characteristics, delivering a structured summary with actionable insights.",
    "whatIsItFor": "The Audience Summary agent analyzes target industries and audience segments, researches relevant news and trends, and creates comprehensive audience intelligence reports."
  },
  "inputs": [
    {
      "type": "text-input",
      "label": "Audience Information",
      "required": true,
      "multiline": true,
      "description": "Describe the industries, audiences, or market segments you want to analyze",
      "placeholder": "Tell us about the target industries or audience segments..."
    },
    {
      "type": "context",
      "label": "Ground with context",
      "required": false,
      "description": "Optionally select artifacts or knowledge to provide additional context"
    },
    {
      "type": "file-upload",
      "label": "Upload CSV",
      "accept": ".csv",
      "maxFiles": 1,
      "required": false,
      "description": "Upload a CSV file containing audience or account data"
    }
  ],
  "contextParameters": [],
  "schemas": [
    {
      "id": "enrich_enrichment_schema",
      "name": "Account Enrichment Schema",
      "schema": {
        "type": "object",
        "required": [
          "accountName",
          "targetIndustries",
          "targetAudiences",
          "industryNews"
        ],
        "properties": {
          "accountName": {
            "type": "string",
            "description": "The name of the company/account"
          },
          "industryNews": {
            "type": "string",
            "description": "Latest web news that are relevant to the target audiences and industries and the user's goals"
          },
          "targetAudiences": {
            "type": "string",
            "description": "audiences within the industries"
          },
          "targetIndustries": {
            "type": "string",
            "description": "Identify key industries from the user's input and documents"
          }
        },
        "additionalProperties": false
      },
      "description": "Schema for enriching account information with structured data"
    }
  ],
  "htmlTemplates": [],
  "actions": [
    {
      "id": "initialize_flow",
      "kind": "InitializeFlow",
      "displayName": "Initialize",
      "showToUser": false
    },
    {
      "id": "enrich_parse",
      "kind": "ParseAccounts",
      "config": {
        "inputVarName": "__messages__",
        "outputVarName": "accounts"
      },
      "showToUser": true,
      "displayName": "Parse Accounts"
    },
    {
      "id": "enrich_loop",
      "kind": "Foreach",
      "index": "accountIndex",
      "items": "=accounts",
      "value": "currentAccount",
      "actions": [
        {
          "id": "enrich_get_schema",
          "kind": "GetStructuredSchema",
          "config": {
            "schemaType": "enrich_enrichment_schema",
            "outputVarName": "enrichmentSchema",
            "includeExtractionType": true
          },
          "showToUser": false,
          "displayName": "Get Schema"
        },
        {
          "id": "enrich_enrich",
          "kind": "StructuredResearchFromLoop",
          "config": {
            "model": "workflow-fast-model",
            "loopVarName": "loop_enrich_loop",
            "systemPrompt": "You are Audience Research Agent. Your role is to enrich the industry information by researching the web and identifying key industries, use comma separated values for the industries. Always maintain factual, concise tone.",
            "outputVarName": "currentEnrichedAccount",
            "queryTemplate": "Campaign Goal: Fill the schema. If you use web search, construct concrete queries (no empty values)",
            "structuredSchemaVar": "vars.enrichmentSchema"
          },
          "showToUser": true,
          "displayName": "Enrichment"
        },
        {
          "id": "enrich_save_account",
          "kind": "SaveDocument",
          "config": {
            "kind": "extract",
            "titlePrefix": "Account Enrichment",
            "contentVarName": "vars.currentEnrichedAccount",
            "documentIdPath": "documentId",
            "titleSuffixPath": "accountName"
          },
          "showToUser": false,
          "displayName": "Save Document"
        },
        {
          "id": "enrich_append_result",
          "kind": "AppendLoopResult",
          "config": {
            "loopVarName": "loop_enrich_loop",
            "resultVarName": "vars.currentEnrichedAccount"
          },
          "showToUser": false,
          "displayName": "Store Result"
        }
      ],
      "showToUser": false,
      "displayName": "Enrich Each Account"
    },
    {
      "id": "enrich_extract_results",
      "kind": "ExtractLoopResults",
      "config": {
        "loopVarName": "loop_enrich_loop",
        "outputVarName": "enrichedAccounts"
      },
      "showToUser": false,
      "displayName": "Extract Results"
    },
    {
      "id": "enrich_format",
      "kind": "FormatEnrichedAccounts",
      "config": {
        "inputVarName": "vars.enrichedAccounts",
        "outputVarName": "formattedReport"
      },
      "showToUser": true,
      "displayName": "Format Report"
    },
    {
      "id": "enrich_save_report",
      "kind": "SaveDocument",
      "config": {
        "kind": "text",
        "titlePrefix": "Account Enrichment Report",
        "contentVarName": "vars.formattedReport",
        "successMessage": "\n\n✅ Account enrichment completed and saved!\n**Document:** {title}\n**ID:** {id}",
        "documentIdVarName": "vars.documentId"
      },
      "showToUser": false,
      "displayName": "Save Report"
    },
    {
      "id": "workflow_end",
      "kind": "WorkflowEnd",
      "displayName": "Complete",
      "showToUser": false
    }
  ],
  "version": 2,
  "is_active": true
}