{
  "schema_version": "2.0",
  "id": "content-generation",
  "name": "Content Generator",
  "description": "Create long-form blog content quickly and consistently.",
  "gettingStarted": {
    "title": "What is Content Generator?",
    "howItWorks": "Describe the topic of the blog you want to write about. The agent will generate a blog post based on the prompt.",
    "whatIsItFor": "The Content Generator creates long-form blog content based on a user prompt."
  },
  "inputs": [
    {
      "type": "prompt",
      "label": "Content Requirements",
      "minLines": 3,
      "required": true,
      "description": "Describe what you want to write about",
      "placeholder": "Tell us about your content requirements..."
    },
    {
      "type": "context",
      "label": "Ground with context",
      "required": false,
      "description": "Optionally select artifacts or knowledge to provide additional context"
    },
    {
      "type": "file-upload",
      "label": "Add more context",
      "required": false,
      "description": "Please add any documents you wish to reference"
    }
  ],
  "contextParameters": [],
  "schemas": [
    {
      "id": "blog",
      "name": "Blog Post Schema",
      "schema": {
        "type": "object",
        "required": [
          "title",
          "excerpt",
          "content",
          "tags",
          "seo",
          "audience"
        ],
        "properties": {
          "seo": {
            "type": "object",
            "required": [
              "meta_description",
              "focus_keyword"
            ],
            "properties": {
              "focus_keyword": {
                "type": "string",
                "description": "Primary SEO keyword"
              },
              "meta_description": {
                "type": "string",
                "description": "SEO meta description (50-160 characters)"
              }
            },
            "description": "SEO-related metadata",
            "additionalProperties": false
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Relevant tags or keywords for the blog post"
          },
          "title": {
            "type": "string",
            "description": "The blog post title"
          },
          "content": {
            "type": "string",
            "description": "The full blog post content in markdown format"
          },
          "excerpt": {
            "type": "string",
            "description": "A brief excerpt or summary of the blog post"
          },
          "audience": {
            "type": "object",
            "required": [
              "intended_audience",
              "audience_characteristics",
              "audience_needs"
            ],
            "properties": {
              "audience_needs": {
                "type": "string",
                "description": "Key needs the content addresses"
              },
              "intended_audience": {
                "type": "string",
                "description": "Description of the intended audience"
              },
              "audience_characteristics": {
                "type": "object",
                "required": [
                  "age_range",
                  "location",
                  "interests",
                  "professional_background"
                ],
                "properties": {
                  "location": {
                    "type": "string",
                    "description": "Geographic focus (e.g., Global, North America)"
                  },
                  "age_range": {
                    "type": "string",
                    "description": "Target age range (e.g., 25-45, All ages)"
                  },
                  "interests": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Main interests relevant to the audience"
                  },
                  "professional_background": {
                    "type": "string",
                    "description": "Professional or educational background"
                  }
                },
                "additionalProperties": false
              }
            },
            "description": "Target audience information",
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "description": "Structured schema for blog post generation with SEO and audience metadata"
    }
  ],
  "htmlTemplates": [
    {
      "id": "blog-template",
      "name": "Standard Blog Template",
      "template": "<article class=\"blog-post\">\n  <header>\n    <h1>{{title}}</h1>\n    <p class=\"excerpt\">{{excerpt}}</p>\n    <div class=\"meta\">\n      <span class=\"tags\">{{#each tags}}<span class=\"tag\">{{this}}</span>{{/each}}</span>\n    </div>\n  </header>\n  <div class=\"content\">\n    {{content}}\n  </div>\n  <footer>\n    <div class=\"audience-info\">\n      <h3>Target Audience</h3>\n      <p>{{audience.intended_audience}}</p>\n    </div>\n  </footer>\n</article>"
    }
  ],
  "actions": [
    {
      "id": "initialize_flow",
      "kind": "InitializeFlow",
      "displayName": "Initialize",
      "showToUser": false
    },
    {
      "id": "get_schema",
      "kind": "GetStructuredSchema",
      "config": {
        "schemaType": "blog",
        "outputVarName": "structuredSchema",
        "schemaHtmlTemplate": "blog-template",
        "outputHtmlTemplateVarName": "htmlTemplate"
      },
      "showToUser": false,
      "displayName": "Get Schema"
    },
    {
      "id": "generate-content_compose",
      "kind": "ComposeMessage",
      "config": {
        "inputVarNames": [],
        "outputVarName": "generatePrompt",
        "messageTemplate": "{userMessage}",
        "includeUserMessage": true
      },
      "showToUser": false,
      "displayName": "Compose Message"
    },
    {
      "id": "generate-content_generate",
      "kind": "GenerateContent",
      "config": {
        "type": "content",
        "model": "workflow-fast-model",
        "temperature": 0.7,
        "artifactKind": "content_item",
        "inputVarName": "vars.generatePrompt",
        "systemPrompt": "You are an expert content writer. Create high-quality, engaging blog content based on the provided prompt and research.",
        "outputVarName": "generatedContent",
        "structuredSchemaVar": "vars.blog"
      },
      "showToUser": true,
      "displayName": "Generate Content"
    },
    {
      "id": "generate-content_save",
      "kind": "SaveDocument",
      "config": {
        "kind": "content_item",
        "titlePrefix": "Generated Content",
        "contentVarName": "vars.generatedContent",
        "documentIdVarName": "vars.documentId"
      },
      "showToUser": false,
      "displayName": "Save"
    },
    {
      "id": "workflow_end",
      "kind": "WorkflowEnd",
      "displayName": "Complete",
      "showToUser": false
    }
  ],
  "version": 2,
  "is_active": true
}